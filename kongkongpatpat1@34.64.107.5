server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://${MONITORING_VM_INTERNAL_IP}:3100/loki/api/v1/push

scrape_configs:
  - job_name: ilgijjan-logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: ilgijjan
          __path__: /logs/spring*.log
